<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloom | Feedback</title>

    <link rel="stylesheet" href="/bloom-style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

    <%- include("partials/header") %>

    <section class="section">
        <div class="container">

            <h2 class="section-title">Feedback</h2>
            <p style="text-align:center; color: var(--text-gray); max-width: 700px; margin: 0 auto 3rem;">
                Please share your experience with Bloom.
            </p>

            <div class="form-container">
              <form action="/feedback" method="POST">

    <div class="form-group">
        <label>Rating (1–5)</label>
        <select name="rating" required>
            <option value="">Select</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
        </select>
    </div>


                    <div class="form-group">
                        <label>What did you purchase?</label>
                        <select name="purchaseType" required>
                            <option value="">Select</option>
                            <option value="plant">Individual Plant</option>
                            <option value="subscription">Subscription Plan</option>
                            <option value="multiple">Multiple Items</option>
                            <option value="browsing">Just Browsing</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Positive Feedback</label>
                        <textarea name="positive" rows="4" required></textarea>
                    </div>

                    <div class="form-group">
                        <label>Areas of Improvement</label>
                        <textarea name="improvement" rows="4" required></textarea>
                    </div>

                    <div class="form-group">
                        <label>Would you recommend Bloom?</label>
                        <div style="display:flex; gap:2rem; margin-top:0.5rem;">
                            <label><input type="radio" name="recommend" value="yes" required> Yes</label>
                            <label><input type="radio" name="recommend" value="maybe" required> Maybe</label>
                            <label><input type="radio" name="recommend" value="no" required> No</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email (optional)</label>
                        <input type="email" name="email">
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">Submit</button>
                </form>
            </div>

            <hr style="margin: 3rem 0;">

            <h3 class="section-title" style="text-align:center;">Submitted Feedback</h3>

            <form action="/feedback/search" method="GET" style="text-align:center; margin-bottom:2rem;">
                <input type="text" name="q" placeholder="Search..." style="padding:0.5rem; width:250px;">
                <button type="submit" class="btn btn-primary">Search</button>
            </form>

            <div>
                <% if (feedbackList) { %>
                    <% feedbackList.forEach(fb => { %>
                        <div style="background:#f5f5f5; padding:1rem; margin-bottom:1rem; border-radius:6px;">
                            <p><strong>Rating:</strong> <%= fb.rating %></p>
                            <p><strong>Purchase:</strong> <%= fb.purchaseType %></p>
                            <p><strong>Positive:</strong> <%= fb.positive %></p>
                            <p><strong>Improvement:</strong> <%= fb.improvement %></p>
                            <p><strong>Recommend:</strong> <%= fb.recommend %></p>
                            <p><strong>Email:</strong> <%= fb.email || "N/A" %></p>

                            <form action="/feedback/delete/<%= fb.id %>" method="POST" style="margin-top:1rem;">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    <% }) %>
                <% } %>
            </div>

        </div>
    </section>

    <%- include("partials/footer") %>

</body>
</html>