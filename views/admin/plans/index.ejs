<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Bloom Admin | Manage Plans</title>
    <link rel="stylesheet" href="/bloom-style.css">

  <style>
    .admin-container {
    max-width: 1000px;
    margin: 50px auto;
    padding: var(--spacing-md);
}

.admin-title {
    font-size: 2rem;
    color: var(--leaf-700);
    text-align: center;
    margin-bottom: var(--spacing-lg);
}

/* Add New Plan Button */
.btn-add {
    display: inline-block;
    background: var(--leaf-600);
    color: white;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-weight: bold;
    margin-bottom: var(--spacing-md);
    transition: 0.2s ease;
}
.btn-add:hover {
    background: var(--leaf-700);
}

/* TABLE CONTAINER */
.admin-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--PolarBear); /* Soft visible contrast */
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

/* HEADER */
.admin-table th {
    background: var(--leaf-500);
    color: white;
    padding: 14px;
    font-size: 1rem;
    text-align: left;
}

/* TABLE ROWS */
.admin-table td {
    padding: 14px;
    color: var(--char-900);
    border-bottom: 1px solid #d6d6cf;
    font-size: 1rem;
}

/* Alternating rows for visibility */
.admin-table tr:nth-child(even) {
    background: #dfe5d9; /* soft muted green-gray */
}
.admin-table tr:nth-child(odd) {
    background: #eef1ec; /* slightly lighter */
}

/* EDIT + DELETE BUTTONS */
.btn-small {
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    background: var(--leaf-600);
    color: white;
    font-size: 0.9rem;
    text-decoration: none;
    transition: 0.2s ease;
}
.btn-small:hover {
    background: var(--leaf-700);
}

/* DELETE BUTTON */
.btn-danger {
    background: var(--error);
}
.btn-danger:hover {
    background: #c0392b;
}

  </style>

</head>

<body>

<%- include("../../partials/header") %>

<div class="admin-container">

    <h1 class="admin-title">Manage Subscription Plans</h1>

    <!-- Add New Plan Button -->
    <a href="/admin/plans/new" class="btn-add">+ Add New Plan</a>

    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Price (SAR)</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            <% plans.forEach(plan => { %>
                <tr>
                    <td><%= plan.id %></td>
                    <td><%= plan.title %></td>
                    <td><%= plan.price %></td>

                    <td>
                        <!-- Edit -->
                        <a href="/admin/plans/edit/<%= plan.id %>" class="btn-small">Edit</a>

                        <!-- Delete -->
                        <form action="/admin/plans/delete/<%= plan.id %>" method="POST" style="display:inline;">
                            <button class="btn-small btn-danger" onclick="return confirm('Delete this plan?')">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</div>

<%- include("../../partials/footer") %>

</body>
</html>
