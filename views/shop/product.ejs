<%- include('../partials/header') %>

<link rel="stylesheet" href="/css/shop.css">

<section class="product-page">

    <div class="container" style="grid-template-columns: 1fr 1fr;">

        <!-- LEFT: Product Image -->
        <div class="product-image-container" style="width:100%; padding-top:100%; position:relative;">
            <img src="<%= product.image %>" alt="<%= product.name %>" 
                 style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; border-radius:var(--radius);">
        </div>

        <!-- RIGHT: Product Information -->
        <div class="product-details" style="padding:2rem;">

            <h1 style="font-size:2rem; color:var(--char-900); margin-bottom:1rem;">
                <%= product.name %>
            </h1>

            <p style="font-size:1.5rem; color:var(--leaf-600); font-weight:700;">
                SAR <%= product.price %>
            </p>

            <p style="margin-top:1rem; color:var(--stone-400); line-height:1.7;">
                <%= product.description %>
            </p>

            <!-- Stock -->
            <p style="margin-top:1rem;">
                <strong>In stock:</strong> <%= product.quantity %>
            </p>

            <!-- CARE SECTION -->
            <div class="care-guide" style="margin-top:2rem;">
                <h3 class="care-guide-title">Care Guide</h3>
                <p style="color:var(--stone-400);">
                    <%= product.care %>
                </p>
            </div>

            <!-- Add to Cart -->
<form action="/cart/add-product/<%= product.id %>" method="POST" style="margin-top:2rem;">
    <label style="font-weight:600;">Quantity:</label>

    <input type="number" 
        name="qty" 
        min="1" 
        max="<%= product.quantity %>" 
        value="1"
        style="width:70px; padding:0.4rem; border-radius:var(--radius); border:1px solid #ccc; margin-left:0.5rem;">
    
    <button type="submit" class="add-to-cart" 
            style="margin-left:1rem; padding:0.75rem 2rem;">
        Add to Cart
    </button>
</form>


        </div>

    </div>

</section>

<%- include('../partials/footer') %>
